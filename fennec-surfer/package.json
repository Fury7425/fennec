    "semver":    "^7.6.0",
    "zod":       "^3.22.4"
  },
  "devDependencies": {
    "@types/node":   "^20.12.0",
    "@types/semver": "^7.5.8",
    "typescript":    "^5.4.5"
  },
  "engines": { "node": ">=20.0.0" }
}
