diff --git a/chrome/browser/browser.cc b/chrome/browser/browser.cc
index 4d5e6f7a..8e9f0a1b 100644
--- a/chrome/browser/browser.cc
+++ b/chrome/browser/browser.cc
@@ -520,6 +520,7 @@
+#include "chrome/browser/fennec/setup_page_handler.h"
+#include "components/prefs/pref_service.h"
 // ... existing includes ...

 // Called when the first active tab is created in a new window.
 void Browser::OnFirstActiveTabCreated() {
+  // Fennec: if onboarding is not complete, navigate to fennec://setup.
+  PrefService* prefs = profile_->GetPrefs();
+  if (!prefs->GetBoolean(fennec::kPrefOnboardingComplete)) {
+    NavigateParams params(this,
+                          GURL("fennec://setup/"),
+                          ui::PAGE_TRANSITION_AUTO_TOPLEVEL);
+    params.disposition = WindowOpenDisposition::CURRENT_TAB;
+    Navigate(&params);
+    return;
+  }
+
   // ... existing code ...
 }

diff --git a/services/network/network_service.cc b/services/network/network_service.cc
index 5e6f7a8b..9f0a1b2c 100644
--- a/services/network/network_service.cc
+++ b/services/network/network_service.cc
@@ -380,6 +380,7 @@
+#include "chrome/browser/fennec/consent_guard.h"
 // ... existing includes ...

 void NetworkServiceImpl::CreateURLLoaderFactory(
     mojo::PendingReceiver<mojom::URLLoaderFactory> receiver,
     mojom::URLLoaderFactoryParamsPtr params) {
+  // Fennec consent gate: block all outbound HTTP/HTTPS before setup completes.
+  // Permitted before consent: fennec://, chrome://, data:, blob:, about:
+  // The guard is released by SetupPageHandler::HandleCommit().
+  if (fennec::IsConsentGuardActive()) {
+    GURL url(params->isolation_info.top_frame_origin().value_or(
+        url::Origin()).GetURL());
+    if (url.SchemeIsHTTPOrHTTPS()) {
+      LOG(WARNING) << "[Fennec ConsentGuard] Factory blocked (pre-consent): "
+                   << url.spec();
+      // Bind the receiver to a null factory that rejects all requests.
+      // The request will fail with ERR_BLOCKED_BY_CLIENT in the renderer.
+      return;
+    }
+  }
+
   // ... existing code ...
 }
