+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+//
+// SetupPageHandler — WebUI message handler for fennec://setup.
+//
+// Receives the commit(state) message from the React frontend and:
+//   1. Parses the JSON state object.
+//   2. Writes service opt-in prefs to the profile's PrefService.
+//   3. Sets fennec.onboarding.complete = true.
+//   4. Calls fennec::ReleaseConsentGuard() to permit network traffic.
+//   5. Navigates the tab to the user's new-tab page.

+#ifndef CHROME_BROWSER_FENNEC_SETUP_PAGE_HANDLER_H_
+#define CHROME_BROWSER_FENNEC_SETUP_PAGE_HANDLER_H_
+
+#include "base/values.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+class Profile;
+
+namespace fennec {
+
+// Pref keys — also used by the consent guard and service clients.
+inline constexpr char kPrefOnboardingComplete[]      = "fennec.onboarding.complete";
+inline constexpr char kPrefEnableUpdates[]           = "fennec.services.enable_updates";
+inline constexpr char kPrefEnableFilterRefresh[]     = "fennec.services.enable_filter_refresh";
+inline constexpr char kPrefEnableModsRegistry[]      = "fennec.services.enable_mods_registry";
+inline constexpr char kPrefEnableCwsProxy[]          = "fennec.services.enable_cws_proxy";
+
+class SetupPageHandler : public content::WebUIMessageHandler {
+ public:
+  explicit SetupPageHandler(Profile* profile);
+  ~SetupPageHandler() override = default;
+
+  // WebUIMessageHandler override.
+  void RegisterMessages() override;
+
+ private:
+  // JS→C++ message handler for "fennec.setup.commit".
+  // |args[0]| is the JSON-encoded SetupState from the React frontend.
+  void HandleCommit(const base::Value::List& args);
+
+  // JS→C++ message handler for "fennec.setup.getVersion".
+  // Resolves the callback with the Fennec version string.
+  void HandleGetVersion(const base::Value::List& args);
+
+  Profile* profile_;  // not owned; outlives this handler
+};
+
+// Registers all Fennec prefs with the given registry.
+// Called from chrome/browser/prefs/browser_prefs.cc.
+void RegisterFennecProfilePrefs(user_prefs::PrefRegistrySyncable* registry);
+
+}  // namespace fennec
+
+#endif  // CHROME_BROWSER_FENNEC_SETUP_PAGE_HANDLER_H_

diff --git a/chrome/browser/fennec/setup_page_handler.cc b/chrome/browser/fennec/setup_page_handler.cc
new file mode 100644
index 00000000..2b3c4d5e
--- /dev/null
+++ b/chrome/browser/fennec/setup_page_handler.cc
@@ -0,0 +1,148 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/setup_page_handler.h"
+
+#include "base/logging.h"
+#include "base/values.h"
+#include "chrome/browser/fennec/consent_guard.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/channel_info.h"
+#include "components/prefs/pref_registry_simple.h"
+#include "components/prefs/pref_service.h"
+#include "components/user_prefs/user_prefs.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/public/browser/web_contents.h"
+#include "content/public/browser/web_ui.h"
+
+namespace fennec {
+
+// ── Pref registration ───────────────────────────────────────────────────────
+
+void RegisterFennecProfilePrefs(user_prefs::PrefRegistrySyncable* registry) {
+  // Onboarding gate.
+  registry->RegisterBooleanPref(kPrefOnboardingComplete, false);
+
+  // Service opt-ins — all false by default (consent-first).
+  registry->RegisterBooleanPref(kPrefEnableUpdates,       false);
+  registry->RegisterBooleanPref(kPrefEnableFilterRefresh, false);
+  registry->RegisterBooleanPref(kPrefEnableModsRegistry,  false);
+  registry->RegisterBooleanPref(kPrefEnableCwsProxy,      false);
+}
+
+// ── SetupPageHandler ────────────────────────────────────────────────────────
+
+SetupPageHandler::SetupPageHandler(Profile* profile)
+    : profile_(profile) {
+  DCHECK(profile_);
+}
+
+void SetupPageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "fennec.setup.commit",
+      base::BindRepeating(&SetupPageHandler::HandleCommit,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "fennec.setup.getVersion",
+      base::BindRepeating(&SetupPageHandler::HandleGetVersion,
+                          base::Unretained(this)));
+}
+
+void SetupPageHandler::HandleGetVersion(const base::Value::List& args) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  AllowJavascript();
+
+  const std::string& callback_id = args[0].GetString();
+  ResolveJavascriptCallback(
+      base::Value(callback_id),
+      base::Value(FENNEC_VERSION_STRING));
+}
+
+void SetupPageHandler::HandleCommit(const base::Value::List& args) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Parse the JSON state from the React frontend.
+  if (args.empty() || !args[0].is_dict()) {
+    LOG(ERROR) << "[SetupPageHandler] HandleCommit: invalid args.";
+    return;
+  }
+
+  const base::Value::Dict& state = args[0].GetDict();
+
+  // ── Parse services ──────────────────────────────────────────────────────
+  const base::Value::Dict* services = state.FindDict("services");
+
+  auto get_bool = [&](const base::Value::Dict* dict,
+                      const char* key) -> bool {
+    if (!dict) return false;
+    const base::Value* v = dict->Find(key);
+    return v && v->GetBool();
+  };
+
+  const bool enable_updates        = get_bool(services, "enableUpdates");
+  const bool enable_filter_refresh = get_bool(services, "enableFilterRefresh");
+  const bool enable_mods_registry  = get_bool(services, "enableModsRegistry");
+  const bool enable_cws_proxy      = get_bool(services, "enableCwsProxy");
+
+  // ── Write prefs ─────────────────────────────────────────────────────────
+  PrefService* prefs = profile_->GetPrefs();
+
+  prefs->SetBoolean(kPrefEnableUpdates,       enable_updates);
+  prefs->SetBoolean(kPrefEnableFilterRefresh, enable_filter_refresh);
+  prefs->SetBoolean(kPrefEnableModsRegistry,  enable_mods_registry);
+  prefs->SetBoolean(kPrefEnableCwsProxy,      enable_cws_proxy);
+
+  // Mark onboarding complete.  This is the key that the consent guard
+  // checks — setting it releases all future network requests.
+  prefs->SetBoolean(kPrefOnboardingComplete, true);
+  prefs->CommitPendingWrite();
+
+  LOG(INFO) << "[SetupPageHandler] Onboarding complete. "
+            << "updates=" << enable_updates
+            << " filter_refresh=" << enable_filter_refresh
+            << " mods=" << enable_mods_registry
+            << " cws_proxy=" << enable_cws_proxy;
+
+  // ── Release the consent guard ────────────────────────────────────────────
+  // After this call, outbound HTTP/HTTPS requests are permitted.
+  fennec::ReleaseConsentGuard();
+
+  // ── Navigate to the new-tab page ─────────────────────────────────────────
+  content::WebContents* wc = web_ui()->GetWebContents();
+  if (wc) {
+    wc->GetController().LoadURL(
+        GURL("fennec://newtab/"),
+        content::Referrer(),
+        ui::PAGE_TRANSITION_AUTO_TOPLEVEL,
+        std::string());
+  }
+}
+
+}  // namespace fennec

