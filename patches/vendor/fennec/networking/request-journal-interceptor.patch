+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+//
+// JournalInterceptor — forwards NetworkService events to RequestJournal.
+//
+// Installed once per BrowserContext via profile_impl.cc.
+// Thread-safe: called on the IO thread; delegates to RequestJournal on
+// the Journal's SQLite task runner via PostTask.
+
+#ifndef CHROME_BROWSER_FENNEC_JOURNAL_INTERCEPTOR_H_
+#define CHROME_BROWSER_FENNEC_JOURNAL_INTERCEPTOR_H_
+
+#include "fennec/src/journal/request_journal.h"
+#include "services/network/public/cpp/resource_request.h"
+#include "url/gurl.h"
+
+namespace fennec {
+
+class JournalInterceptor {
+ public:
+  explicit JournalInterceptor(journal::RequestJournal* journal);
+  ~JournalInterceptor() = default;
+
+  // Called on IO thread for every outbound request.
+  // Returns the entry_id for use in OnResponse / OnBlock.
+  int64_t OnRequest(const network::ResourceRequest& request,
+                    const std::string& top_frame_url);
+
+  // Called when a response is received.
+  void OnResponse(int64_t entry_id, int http_status, int64_t bytes);
+
+  // Called when a request is blocked (consent guard or uBO).
+  void OnBlock(int64_t entry_id, const std::string& reason);
+
+ private:
+  journal::RequestJournal* journal_;  // not owned; outlives this
+};
+
+}  // namespace fennec
+
+#endif  // CHROME_BROWSER_FENNEC_JOURNAL_INTERCEPTOR_H_

diff --git a/chrome/browser/fennec/journal_interceptor.cc b/chrome/browser/fennec/journal_interceptor.cc
new file mode 100644
index 00000000..3c4d5e6f
--- /dev/null
+++ b/chrome/browser/fennec/journal_interceptor.cc
@@ -0,0 +1,74 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/journal_interceptor.h"
+
+#include "base/logging.h"
+#include "base/strings/string_util.h"
+
+namespace fennec {
+
+JournalInterceptor::JournalInterceptor(journal::RequestJournal* journal)
+    : journal_(journal) {
+  DCHECK(journal_);
+}
+
+int64_t JournalInterceptor::OnRequest(
+    const network::ResourceRequest& request,
+    const std::string& top_frame_url) {
+
+  // Extract initiator URL from the request.
+  GURL initiator_url;
+  if (request.request_initiator.has_value()) {
+    initiator_url = request.request_initiator->GetURL();
+  }
+
+  // Map Chromium resource_type enum to a human-readable string.
+  const std::string res_type = ResourceTypeToString(request.resource_type);
+
+  // RecordRequest classifies and persists asynchronously.
+  // Returns the classification immediately (synchronous classification).
+  journal::RequestClass cls = journal_->RecordRequest(
+      request.url,
+      initiator_url,
+      /* initiator_script= */ "",  // TODO: extract from DevTools frame tree
+      res_type,
+      top_frame_url);
+
+  // Return a synthetic entry ID for now.
+  // TODO: RecordRequest should return the assigned row ID after async insert.
+  (void)cls;
+  return 0;
+}
+
+void JournalInterceptor::OnResponse(int64_t entry_id,
+                                     int http_status,
+                                     int64_t bytes) {
+  journal_->RecordResponse(entry_id, http_status, bytes);
+}
+
+void JournalInterceptor::OnBlock(int64_t entry_id,
+                                  const std::string& reason) {
+  journal_->RecordBlock(entry_id, reason);
+}
+
+// static
+std::string JournalInterceptor::ResourceTypeToString(int resource_type) {
+  // Maps network::mojom::RequestDestination to a label.
+  switch (resource_type) {
+    case 0:  return "document";
+    case 1:  return "frame";
+    case 3:  return "stylesheet";
+    case 4:  return "script";
+    case 5:  return "image";
+    case 7:  return "font";
+    case 10: return "xhr";
+    case 15: return "fetch";
+    case 16: return "websocket";
+    default: return "other";
+  }
+}
+
+}  // namespace fennec
+
