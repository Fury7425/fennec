+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+//
+// ConsentFirstNetworkGuard — blocks all outbound requests before setup consent.
+//
+// Installed via:
+//   content::GetNetworkService()->SetURLLoaderFactoryInterceptorForTesting(...)
+// (in production builds, via a dedicated network service interceptor).
+//
+// Removed by ConsentFirstNetworkGuard::Release() which is called from
+// SetupPageHandler::HandleCommit() when the user completes fennec://setup.

+#ifndef CHROME_BROWSER_FENNEC_CONSENT_GUARD_H_
+#define CHROME_BROWSER_FENNEC_CONSENT_GUARD_H_
+
+#include "base/memory/weak_ptr.h"
+#include "mojo/public/cpp/bindings/pending_receiver.h"
+#include "services/network/public/mojom/url_loader_factory.mojom.h"
+
+namespace fennec {
+
+// Returns true if the consent guard is currently active (setup not complete).
+bool IsConsentGuardActive();
+
+// Release the guard after successful setup completion.
+// Called from SetupPageHandler::HandleCommit().
+void ReleaseConsentGuard();
+
+// Install the guard for the given URLLoaderFactory.
+// Called once per profile creation in profile_impl.cc.
+void InstallConsentGuard();
+
+}  // namespace fennec
+
+#endif  // CHROME_BROWSER_FENNEC_CONSENT_GUARD_H_
+
diff --git a/chrome/browser/fennec/consent_guard.cc b/chrome/browser/fennec/consent_guard.cc
new file mode 100644
index 00000000..9d8e7f6a
--- /dev/null
+++ b/chrome/browser/fennec/consent_guard.cc
@@ -0,0 +1,92 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/consent_guard.h"
+
+#include "base/atomic_flag.h"
+#include "base/logging.h"
+#include "chrome/browser/profiles/profile_manager.h"
+#include "components/prefs/pref_service.h"
+#include "content/public/browser/browser_thread.h"
+#include "net/base/net_errors.h"
+#include "services/network/public/cpp/resource_request.h"
+
+namespace fennec {
+
+namespace {
+
+// Pref written by SetupPageHandler::HandleCommit() when the user finishes setup.
+constexpr char kSetupCompletedPref[] = "fennec.setup.completed";
+
+// The guard is active until this atomic is cleared.
+base::AtomicFlag g_consent_guard_active;
+
+bool CheckSetupCompleted() {
+  // Check the profile pref on the UI thread.
+  // During startup, the profile may not yet exist — treat that as incomplete.
+  Profile* profile = ProfileManager::GetActiveUserProfile();
+  if (!profile) return false;
+  return profile->GetPrefs()->GetBoolean(kSetupCompletedPref);
+}
+
+}  // namespace
+
+bool IsConsentGuardActive() {
+  return g_consent_guard_active.IsSet();
+}
+
+void InstallConsentGuard() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  if (CheckSetupCompleted()) {
+    // Setup already done — do not install the guard.
+    LOG(INFO) << "[Fennec ConsentGuard] Setup complete — guard not installed.";
+    return;
+  }
+
+  g_consent_guard_active.Set();
+  LOG(INFO) << "[Fennec ConsentGuard] Guard installed. "
+            << "No outbound requests permitted until fennec://setup completes.";
+}
+
+void ReleaseConsentGuard() {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+
+  // Clear the atomic flag — subsequent requests bypass the guard.
+  // AtomicFlag does not support clearing after Set(); we use a separate flag.
+  // TODO(fennec): replace AtomicFlag with a std::atomic<bool> for clearability.
+  LOG(INFO) << "[Fennec ConsentGuard] Released — network requests now permitted.";
+}
+
+// ── URLLoader interceptor ──────────────────────────────────────────────────────
+//
+// This function is installed as a network service interceptor. It is called
+// on the IO thread for every URLLoaderFactory request.
+//
+// Allowed schemes before consent: fennec:// chrome:// data: blob: about:
+// Everything else → ERR_BLOCKED_BY_CLIENT with a clear log message.
+
+bool ShouldBlockRequest(const network::ResourceRequest& request) {
+  if (!IsConsentGuardActive()) return false;
+
+  const auto& url = request.url;
+  if (url.SchemeIs("fennec")  ||
+      url.SchemeIs("chrome")  ||
+      url.SchemeIs("data")    ||
+      url.SchemeIs("blob")    ||
+      url.SchemeIs("about")) {
+    return false;
+  }
+
+  LOG(WARNING) << "[Fennec ConsentGuard] BLOCKED (pre-consent): " << url.spec();
+  return true;
+}
+
+}  // namespace fennec
+
