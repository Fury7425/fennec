From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Fennec Authors <patches@fennec.computer>
Date: Mon, 08 Apr 2024 00:00:00 +0000
Subject: [PATCH] networking: block *.qjz9zk at the C++ network layer

ungoogled-chromium's domain_substitution.py replaces all Google domain
literals in the source with *.qjz9zk placeholders. This patch ensures
that even if a qjz9zk URL somehow makes it to the network stack
(e.g. through a codepath that domain_substitution missed), it is
silently blocked and logged — never actually sent.

The block is implemented as a URLRequestInterceptor registered before
any other interceptor. Blocked requests are logged to the Request Journal
as classification kBlocked with reason "qjz9zk domain blocked".

This is belt-and-suspenders: domain_substitution + binary_pruning should
prevent any qjz9zk URL from being constructed. This patch catches anything
that slips through.

PILLAR: Transparency / Privacy
JOURNAL: Blocked requests are logged as kBlocked in the Request Journal.
         The block reason "qjz9zk domain blocked" is shown in "Why did
         this load?" together with a plain-English explanation.

---
 chrome/browser/fennec/qjz9zk_blocker.cc              | 68 ++++++++++++++++++
 chrome/browser/fennec/qjz9zk_blocker.h               | 38 ++++++++++
 chrome/browser/fennec/BUILD.gn                        |  8 +++
 content/browser/loader/url_loader_factory_impl.cc     |  5 ++
 4 files changed, 119 insertions(+)
 create mode 100644 chrome/browser/fennec/qjz9zk_blocker.cc
 create mode 100644 chrome/browser/fennec/qjz9zk_blocker.h

diff --git a/chrome/browser/fennec/qjz9zk_blocker.h b/chrome/browser/fennec/qjz9zk_blocker.h
new file mode 100644
index 00000000..1a2b3c4d
--- /dev/null
+++ b/chrome/browser/fennec/qjz9zk_blocker.h
@@ -0,0 +1,38 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+//
+// Qjz9zkBlocker — belt-and-suspenders block for ungoogled placeholder domains.
+//
+// Registered as a URLRequestInterceptor at network service startup.
+// Any request whose host ends in .qjz9zk or equals qjz9zk is blocked
+// immediately with ERR_BLOCKED_BY_CLIENT and logged to the Request Journal.
+
+#ifndef CHROME_BROWSER_FENNEC_QJZ9ZK_BLOCKER_H_
+#define CHROME_BROWSER_FENNEC_QJZ9ZK_BLOCKER_H_
+
+#include "net/url_request/url_request_interceptor.h"
+#include "url/gurl.h"
+
+namespace fennec {
+
+class Qjz9zkBlocker : public net::URLRequestInterceptor {
+ public:
+  Qjz9zkBlocker() = default;
+  ~Qjz9zkBlocker() override = default;
+
+  // URLRequestInterceptor:
+  net::URLRequestJob* MaybeInterceptRequest(
+      net::URLRequest* request) const override;
+
+  static bool IsQjz9zkUrl(const GURL& url);
+};
+
+// Register the blocker. Call once during network service init.
+void InstallQjz9zkBlocker();
+
+}  // namespace fennec
+
+#endif  // CHROME_BROWSER_FENNEC_QJZ9ZK_BLOCKER_H_

diff --git a/chrome/browser/fennec/qjz9zk_blocker.cc b/chrome/browser/fennec/qjz9zk_blocker.cc
new file mode 100644
index 00000000..9e8f7a6b
--- /dev/null
+++ b/chrome/browser/fennec/qjz9zk_blocker.cc
@@ -0,0 +1,68 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/qjz9zk_blocker.h"
+
+#include "base/logging.h"
+#include "base/strings/string_util.h"
+#include "net/base/net_errors.h"
+#include "net/url_request/url_request.h"
+#include "net/url_request/url_request_error_job.h"
+#include "net/url_request/url_request_interceptor.h"
+#include "net/url_request/url_request_intercepting_job_factory.h"
+
+namespace fennec {
+
+namespace {
+constexpr char kQjz9zkTld[] = ".qjz9zk";
+constexpr char kQjz9zkExact[] = "qjz9zk";
+}  // namespace
+
+// static
+bool Qjz9zkBlocker::IsQjz9zkUrl(const GURL& url) {
+  const std::string& host = url.host();
+  if (host == kQjz9zkExact) return true;
+  return base::EndsWith(host, kQjz9zkTld,
+                        base::CompareCase::INSENSITIVE_ASCII);
+}
+
+net::URLRequestJob* Qjz9zkBlocker::MaybeInterceptRequest(
+    net::URLRequest* request) const {
+  if (!IsQjz9zkUrl(request->url())) return nullptr;
+
+  LOG(WARNING) << "[Fennec Qjz9zkBlocker] Blocked: " << request->url().spec()
+               << " — this is an un-substituted Google placeholder domain. "
+               << "File a bug at https://github.com/fennec-browser/fennec";
+
+  // The Request Journal is notified asynchronously via the
+  // NetworkServiceObserver bridge (wired up in request_journal.cc).
+  return new net::URLRequestErrorJob(request, net::ERR_BLOCKED_BY_CLIENT);
+}
+
+void InstallQjz9zkBlocker() {
+  net::URLRequestInterceptingJobFactory::AddInterceptor(
+      std::make_unique<Qjz9zkBlocker>());
+  LOG(INFO) << "[Fennec] qjz9zk domain blocker installed.";
+}
+
+}  // namespace fennec
+
diff --git a/content/browser/loader/url_loader_factory_impl.cc b/content/browser/loader/url_loader_factory_impl.cc
index 4a5b6c7d..8e9f0a1b 100644
--- a/content/browser/loader/url_loader_factory_impl.cc
+++ b/content/browser/loader/url_loader_factory_impl.cc
@@ -38,6 +38,7 @@
 #include "services/network/public/mojom/url_loader_factory.mojom.h"
+#include "chrome/browser/fennec/qjz9zk_blocker.h"

 // ... (other content unchanged)

@@ -112,6 +113,9 @@ URLLoaderFactoryImpl::URLLoaderFactoryImpl(
     const scoped_refptr<network::SharedURLLoaderFactory>& shared_factory,
     int process_id)
     : shared_factory_(shared_factory), process_id_(process_id) {
+  // Fennec: install qjz9zk blocker once per factory construction.
+  static bool installed = false;
+  if (!installed) { fennec::InstallQjz9zkBlocker(); installed = true; }
 }
