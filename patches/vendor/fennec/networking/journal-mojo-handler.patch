+#ifndef CHROME_BROWSER_UI_WEBUI_FENNEC_JOURNAL_UI_H_
+#define CHROME_BROWSER_UI_WEBUI_FENNEC_JOURNAL_UI_H_
+
+#include "content/public/browser/web_ui_controller.h"
+
+namespace fennec {
+
+// WebUIController for fennec://journal.
+// Registers the journal React bundle as a data source and installs
+// JournalMojoHandler as the message handler.
+class FennecJournalUI : public content::WebUIController {
+ public:
+  explicit FennecJournalUI(content::WebUI* web_ui);
+  ~FennecJournalUI() override = default;
+
+  FennecJournalUI(const FennecJournalUI&) = delete;
+  FennecJournalUI& operator=(const FennecJournalUI&) = delete;
+};
