+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/ui/webui/fennec_journal_ui.h"
+
+#include "chrome/browser/fennec/journal_mojo_handler.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/grit/fennec_webui_resources.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+#include "fennec/journal/request_journal.h"
+
+namespace fennec {
+
+namespace {
+
+// Returns the RequestJournal for the current profile.
+// Created lazily by ProfileKeyedServiceFactory.
+RequestJournal* GetJournalForProfile(Profile* profile) {
+  return RequestJournalFactory::GetForProfile(profile);
+}
+
+}  // namespace
+
+FennecJournalUI::FennecJournalUI(content::WebUI* web_ui)
+    : WebUIController(web_ui) {
+  Profile* profile = Profile::FromWebUI(web_ui);
+
+  // Create the HTML data source.
+  content::WebUIDataSource* source =
+      content::WebUIDataSource::CreateAndAdd(profile, "journal");
+
+  // Register the compiled React bundle resources.
+  source->AddResourcePath("",          IDR_FENNEC_JOURNAL_HTML);
+  source->AddResourcePath("main.js",   IDR_FENNEC_JOURNAL_JS);
+  source->AddResourcePath("style.css", IDR_FENNEC_JOURNAL_CSS);
+  source->SetDefaultResource(IDR_FENNEC_JOURNAL_HTML);
+
+  source->DisableTrustedTypesCSP();
+  source->UseStringsJs();
+
+  // Install the message handler.
+  web_ui->AddMessageHandler(
+      std::make_unique<JournalMojoHandler>(GetJournalForProfile(profile)));
+}
+
+}  // namespace fennec

