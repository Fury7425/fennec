+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+//
+// JournalMojoHandler — WebUI message handler for fennec://journal.
+//
+// Lifecycle:
+//   Created by FennecJournalUI when the renderer loads fennec://journal.
+//   Destroyed when the WebUI is torn down.
+//
+// Thread model:
+//   Constructed and destroyed on the UI thread.
+//   OnNewEntry() is called from the Journal's SQLite task runner; it
+//   bounces to the UI thread before calling back into the renderer.

+#ifndef CHROME_BROWSER_FENNEC_JOURNAL_MOJO_HANDLER_H_
+#define CHROME_BROWSER_FENNEC_JOURNAL_MOJO_HANDLER_H_
+
+#include <string>
+
+#include "base/memory/weak_ptr.h"
+#include "content/public/browser/web_ui_message_handler.h"
+#include "fennec/journal/request_journal.h"
+
+namespace fennec {
+
+class JournalMojoHandler
+    : public content::WebUIMessageHandler,
+      public RequestJournalObserver {
+ public:
+  explicit JournalMojoHandler(RequestJournal* journal);
+  ~JournalMojoHandler() override;
+
+  // WebUIMessageHandler overrides.
+  void RegisterMessages() override;
+
+  // RequestJournalObserver override — called on the journal task runner.
+  void OnNewEntry(const JournalEntry& entry) override;
+
+ private:
+  // JS → C++ message handlers.
+  void HandleGetEntries(const base::Value::List& args);
+  void HandleExportJson(const base::Value::List& args);
+  void HandleClear(const base::Value::List& args);
+  void HandleSubscribe(const base::Value::List& args);
+  void HandleUnsubscribe(const base::Value::List& args);
+
+  // Serialises a JournalEntry to a base::Value::Dict for JSON transport.
+  static base::Value::Dict EntryToValue(const JournalEntry& entry);
+
+  // Called on the UI thread to push an entry to all subscribed renderers.
+  void DispatchNewEntry(const JournalEntry& entry);
+
+  RequestJournal* journal_;  // not owned; owned by the Profile
+  int             subscription_id_ = -1;
+
+  base::WeakPtrFactory<JournalMojoHandler> weak_factory_{this};
+};
+
+}  // namespace fennec
+
+#endif  // CHROME_BROWSER_FENNEC_JOURNAL_MOJO_HANDLER_H_

diff --git a/chrome/browser/fennec/journal_mojo_handler.cc b/chrome/browser/fennec/journal_mojo_handler.cc
new file mode 100644
index 00000000..b2c3d4e5
--- /dev/null
+++ b/chrome/browser/fennec/journal_mojo_handler.cc
@@ -0,0 +1,142 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/journal_mojo_handler.h"
+
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/task/sequenced_task_runner.h"
+#include "base/values.h"
+#include "content/public/browser/browser_thread.h"
+#include "content/public/browser/web_ui.h"
+
+namespace fennec {
+
+JournalMojoHandler::JournalMojoHandler(RequestJournal* journal)
+    : journal_(journal) {
+  DCHECK(journal_);
+
+  // Subscribe to live updates.  The subscription is removed in the
+  // destructor via journal_->Unsubscribe().
+  subscription_id_ = journal_->Subscribe(
+      this,
+      base::SequencedTaskRunner::GetCurrentDefault());
+}
+
+JournalMojoHandler::~JournalMojoHandler() {
+  if (subscription_id_ >= 0)
+    journal_->Unsubscribe(subscription_id_);
+}
+
+void JournalMojoHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "fennec.journal.getEntries",
+      base::BindRepeating(&JournalMojoHandler::HandleGetEntries,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "fennec.journal.exportJson",
+      base::BindRepeating(&JournalMojoHandler::HandleExportJson,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "fennec.journal.clear",
+      base::BindRepeating(&JournalMojoHandler::HandleClear,
+                          base::Unretained(this)));
+}
+
+// static
+base::Value::Dict JournalMojoHandler::EntryToValue(const JournalEntry& e) {
+  base::Value::Dict obj;
+  obj.Set("id",              static_cast<double>(e.id));
+  obj.Set("timestamp",       e.timestamp.ToJsTimeIgnoringNull());
+  obj.Set("url",             e.url);
+  obj.Set("resource_type",   e.resource_type);
+  obj.Set("source_url",      e.source_url);
+  obj.Set("initiator_url",   e.initiator_url);
+  obj.Set("source_tag",      e.source_tag);
+  obj.Set("status_code",     e.status_code);
+  obj.Set("mime_type",       e.mime_type);
+  obj.Set("blocked",         e.blocked);
+  obj.Set("block_reason",    e.block_reason);
+  obj.Set("resource_class",  ResourceClassLabel(e.resource_class));
+  obj.Set("response_bytes",  static_cast<double>(e.response_bytes));
+  return obj;
+}
+
+void JournalMojoHandler::HandleGetEntries(const base::Value::List& args) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  AllowJavascript();
+
+  const std::string& callback_id = args[0].GetString();
+  int limit = args.size() > 1 ? args[1].GetInt() : 500;
+
+  const auto entries = journal_->GetRecentEntries(limit);
+  base::Value::List list;
+  for (const auto& e : entries)
+    list.Append(EntryToValue(e));
+
+  std::string json;
+  base::JSONWriter::Write(base::Value(std::move(list)), &json);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(json));
+}
+
+void JournalMojoHandler::HandleExportJson(const base::Value::List& args) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  int days = args.size() > 0 ? args[0].GetInt() : 7;
+
+  const std::string json = journal_->ExportAsJson(days);
+  // Trigger a download via a data URL in the renderer.
+  // The JS bridge calls window.__fennec.journal.exportJson() which calls
+  // this handler; we respond by firing a custom event back with the data.
+  base::Value::Dict event;
+  event.Set("type",     "fennec-journal-export");
+  event.Set("data",     json);
+  event.Set("filename", base::StringPrintf(
+      "fennec-journal-%s.json",
+      base::Time::Now().UTCExplode().Str().c_str()));
+
+  std::string event_json;
+  base::JSONWriter::Write(base::Value(std::move(event)), &event_json);
+  web_ui()->CallJavascriptFunctionUnsafe(
+      "window.__fennec_journal_on_export",
+      base::Value(event_json));
+}
+
+void JournalMojoHandler::HandleClear(const base::Value::List& /*args*/) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  journal_->Clear();
+}
+
+// Called on the journal task runner → bounce to UI.
+void JournalMojoHandler::OnNewEntry(const JournalEntry& entry) {
+  // We are on the journal task runner here; post to UI thread.
+  content::GetUIThreadTaskRunner({})->PostTask(
+      FROM_HERE,
+      base::BindOnce(&JournalMojoHandler::DispatchNewEntry,
+                     weak_factory_.GetWeakPtr(),
+                     entry));
+}
+
+void JournalMojoHandler::DispatchNewEntry(const JournalEntry& entry) {
+  DCHECK_CURRENTLY_ON(content::BrowserThread::UI);
+  if (!IsJavascriptAllowed()) return;
+
+  base::Value::Dict obj = EntryToValue(entry);
+  std::string json;
+  base::JSONWriter::Write(base::Value(std::move(obj)), &json);
+
+  // Fire into the subscribed renderer callbacks registered from JS.
+  web_ui()->CallJavascriptFunctionUnsafe(
+      "window.__fennec_journal_on_entry",
+      base::Value(json));
+}
+
+}  // namespace fennec

