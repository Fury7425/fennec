 // ... (other includes unchanged)

@@ -318,6 +319,9 @@ WebUIFactoryFunction GetWebUIFactoryFunction(WebUI* web_ui,
     return &NewWebUI<AboutUI>;
   }

+  if (url.SchemeIs("fennec") && url.host() == "about") {
+    return &NewWebUI<AboutFennecUI>;
+  }
+
   if (url.host_piece() == chrome::kChromeUIChromeURLsHost) {
     return &NewWebUI<ChromeURLsUI>;
   }
