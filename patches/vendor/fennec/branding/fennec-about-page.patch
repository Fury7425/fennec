index 00000000..3a4b5c6d
--- /dev/null
+++ b/chrome/browser/fennec/about_fennec_ui.h
@@ -0,0 +1,35 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#ifndef CHROME_BROWSER_FENNEC_ABOUT_FENNEC_UI_H_
+#define CHROME_BROWSER_FENNEC_ABOUT_FENNEC_UI_H_
+
+#include "content/public/browser/web_ui_controller.h"
+#include "content/public/browser/web_ui_data_source.h"
+
+namespace content {
+class WebUI;
+}
+
+// WebUI controller for fennec://about.
+// Serves the compiled React bundle from
+// chrome/browser/resources/fennec/about/.
+class AboutFennecUI : public content::WebUIController {
+ public:
+  explicit AboutFennecUI(content::WebUI* web_ui);
+  ~AboutFennecUI() override;
+
+  AboutFennecUI(const AboutFennecUI&) = delete;
+  AboutFennecUI& operator=(const AboutFennecUI&) = delete;
+
+ private:
+  static void AddFennecAboutResources(content::WebUIDataSource* source);
+};
+
+#endif  // CHROME_BROWSER_FENNEC_ABOUT_FENNEC_UI_H_
+
diff --git a/chrome/browser/fennec/about_fennec_ui.cc b/chrome/browser/fennec/about_fennec_ui.cc
new file mode 100644
index 00000000..5d6e7f8a
--- /dev/null
+++ b/chrome/browser/fennec/about_fennec_ui.cc
@@ -0,0 +1,82 @@
+// Copyright 2024 The Fennec Authors. All rights reserved.
+// Use of this source code is governed by a GPL-3.0 license.
+
+#include "chrome/browser/fennec/about_fennec_ui.h"
+
+#include "chrome/browser/fennec/fennec_version.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/browser/ui/webui/webui_util.h"
+#include "chrome/common/channel_info.h"
+#include "chrome/grit/fennec_about_resources.h"   // generated by GN
+#include "chrome/grit/fennec_about_resources_map.h"
+#include "components/version_info/version_info.h"
+#include "content/public/browser/web_ui.h"
+#include "content/public/browser/web_ui_data_source.h"
+
+namespace {
+
+// Data strings injected into the page at load time.
+// The React bundle reads these via chrome.send() / cr.sendWithPromise().
+void PopulateVersionStrings(content::WebUIDataSource* source) {
+  source->AddString("fennecVersion",    FENNEC_VERSION);
+  source->AddString("fennecChannel",    FENNEC_CHANNEL);
+  source->AddString("fennecBuildDate",  kFennecBuildDate);
+  source->AddString("chromiumVersion",
+                    version_info::GetVersionNumber());
+  source->AddString("fennecHomepage",   FENNEC_HOMEPAGE_URL);
+  source->AddString("fennecSourceUrl",
+                    "https://github.com/fennec-browser/fennec");
+  source->AddString("fennecLicense",
+                    "GPL-3.0-only");
+  source->AddString("chromiumLicense",
+                    "BSD 3-Clause");
+  source->AddString("uboLicense",
+                    "GPL-3.0");
+}
+
+}  // namespace
+
+AboutFennecUI::AboutFennecUI(content::WebUI* web_ui)
+    : content::WebUIController(web_ui) {
+  content::WebUIDataSource* source =
+      content::WebUIDataSource::CreateAndAdd(
+          Profile::FromWebUI(web_ui),
+          "about");  // served at fennec://about
+
+  PopulateVersionStrings(source);
+  AddFennecAboutResources(source);
+
+  webui::SetupWebUIDataSource(
+      source,
+      base::make_span(kFennecAboutResources,
+                      kFennecAboutResourcesSize),
+      IDR_FENNEC_ABOUT_INDEX_HTML);
+}
+
+AboutFennecUI::~AboutFennecUI() = default;
+
+// static
+void AboutFennecUI::AddFennecAboutResources(
+    content::WebUIDataSource* source) {
+  // CSP: allow inline styles (Tailwind) and no external sources.
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::ScriptSrc,
+      "script-src chrome://resources 'self';");
+  source->OverrideContentSecurityPolicy(
+      network::mojom::CSPDirectiveName::StyleSrc,
+      "style-src 'self' 'unsafe-inline';");
+  source->DisableTrustedTypesCSP();
+}
+
