{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FennecModManifest",
  "description": "Manifest schema for sandboxed Fennec Mods.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "author",
    "description",
    "license",
    "fennec_min_version",
    "surfaces"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "author": {
      "type": "string",
      "minLength": 1,
      "maxLength": 96
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "license": {
      "type": "string",
      "enum": [
        "GPL-3.0",
        "GPL-3.0-only",
        "GPL-3.0-or-later",
        "AGPL-3.0",
        "AGPL-3.0-only",
        "AGPL-3.0-or-later",
        "LGPL-3.0",
        "LGPL-3.0-only",
        "LGPL-3.0-or-later"
      ]
    },
    "fennec_min_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "surfaces": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "sidebar",
          "newtab",
          "settings",
          "journal",
          "layout"
        ]
      }
    },
    "css": {
      "type": "string"
    },
    "js": {
      "type": "string"
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "icon",
        "entry"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "icon": {
          "type": "string",
          "minLength": 1
        },
        "entry": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      },
      "propertyNames": {
        "type": "string",
        "pattern": "^--fennec-[a-z0-9-]+$"
      }
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "presetName",
        "config"
      ],
      "properties": {
        "presetName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 96
        },
        "config": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "sidebar",
            "toolbar",
            "addressBar",
            "journalPanel",
            "splitViewDefault"
          ],
          "properties": {
            "sidebar": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "position",
                "displayMode"
              ],
              "properties": {
                "position": {
                  "type": "string",
                  "enum": [
                    "left",
                    "right",
                    "hidden"
                  ]
                },
                "displayMode": {
                  "type": "string",
                  "enum": [
                    "collapsed",
                    "expanded"
                  ]
                }
              }
            },
            "toolbar": {
              "type": "string",
              "enum": [
                "top",
                "bottom",
                "hidden"
              ]
            },
            "addressBar": {
              "type": "string",
              "enum": [
                "top-center",
                "sidebar-top",
                "hidden"
              ]
            },
            "journalPanel": {
              "type": "string",
              "enum": [
                "sidebar-bottom-drawer",
                "floating-panel",
                "hidden"
              ]
            },
            "splitViewDefault": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
